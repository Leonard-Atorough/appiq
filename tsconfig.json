      "@shared": ["./src/shared"],
      "@shared/*": ["./src/shared/*"],
      "@app": ["./src/app"],
      "@app/*": ["./src/app/*"],
      "@features": ["./src/features"],
      "@features/*": ["./src/features/*"],
      "@pages": ["./src/pages"],
      "@pages/*": ["./src/pages/*"],
      "@widgets": ["./src/widgets"],
      "@widgets/*": ["./src/widgets/*"]
    }
  }
}
